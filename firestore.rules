rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // An "admin" is any signed-in user whose UID has a document in
    // the /admins collection. You create those documents by hand in
    // the Firebase console (see DOCUMENTATION.md → Firebase setup).
    // ─────────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── PRODUCTS ── public catalog, writable only by admins ──────
    match /products/{id} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.price is number
        && request.resource.data.price >= 0;
      allow delete: if isAdmin();
    }

    // ── REVIEWS ── anyone can post (validated); admins can delete ─
    match /reviews/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['name','rating','message','createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 40
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 3
        && request.resource.data.message.size() <= 500;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ── CONTACT MESSAGES ── anyone can send; only admins can read ─
    match /messages/{id} {
      allow read, delete: if isAdmin();
      // admins may only flip the "read" flag
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if request.resource.data.keys().hasOnly(['name','email','subject','message','read','createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.email is string
        && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
        && request.resource.data.subject is string
        && request.resource.data.subject.size() <= 100
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 3
        && request.resource.data.message.size() <= 2000
        && request.resource.data.read == false;
    }

    // ── NEWSLETTER ── doc ID is the email; create-only for public ─
    match /newsletter/{email} {
      allow read, delete: if isAdmin();
      allow update: if false;
      allow create: if request.resource.data.keys().hasOnly(['email','createdAt'])
        && request.resource.data.email is string
        && request.resource.data.email == email
        && request.resource.data.email.size() <= 120
        && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$');
    }

    // ── ADMINS ── managed only from the Firebase console ──────────
    match /admins/{uid} {
      allow get: if request.auth != null && request.auth.uid == uid;
      allow list, write: if false;
    }
  }
}
